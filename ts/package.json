{
  "name": "@health-education-england/cct-calc-core",
  "version": "0.1.0",
  "description": "Shared CCT calculation engine driven by a JSON rule definition",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "rules"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/health-education-england/cct-calc-core.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "dayjs": ">=1.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dayjs": "^1.11.13",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
